ids <- ids[, 1]
} else { #getting ids if list of IDs
ids <- as.integer(idsFile)  # assume it's a test.name or back.name, for now
}
ids
length(ids)
if (m > length(intersect(ids, names(countIDs)))) {
m <- length(intersect(ids, names(countIDs)))
}
m
